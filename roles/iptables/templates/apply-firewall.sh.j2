#!/usr/bin/env bash
# {{ ansible_managed }}
# Host firewall cho node K8s ({{ node_role }}).
# Bảo vệ port control-plane/etcd/kubelet: chỉ cho node trong cụm + pod/service
# CIDR (+ admin_cidrs) truy cập; bên ngoài quản trị qua HAProxy {{ master_ha.vip_port | default(8443) }}.
# Không đụng INPUT policy / nat / mangle / FORWARD → Calico + kube-proxy nguyên vẹn.
set -euo pipefail

CHAIN=K8S-FW

# Tạo + làm sạch chain riêng (không flush bảng filter của Calico/kube-proxy)
iptables -N "$CHAIN" 2>/dev/null || true
iptables -F "$CHAIN"

# --- Traffic tin cậy: RETURN về INPUT (cho stack xử lý tiếp) ---
iptables -A "$CHAIN" -i lo -j RETURN
iptables -A "$CHAIN" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
iptables -A "$CHAIN" -p icmp -j RETURN

# Mọi node trong cụm (etcd, kubelet, calico, kube-proxy, VRRP…)
{% for h in (groups['masters'] | default([])) + (groups['workers'] | default([])) %}
iptables -A "$CHAIN" -s {{ hostvars[h].ansible_host | default(h) }} -j RETURN
{% endfor %}

# Pod & Service CIDR
iptables -A "$CHAIN" -s {{ network.pod_cidr }} -j RETURN
iptables -A "$CHAIN" -s {{ network.service_cidr }} -j RETURN

{% if firewall.admin_cidrs | default([]) | length > 0 %}
# Dải quản trị bổ sung
{% for cidr in firewall.admin_cidrs %}
iptables -A "$CHAIN" -s {{ cidr }} -j RETURN
{% endfor %}
{% endif %}

{% if node_role == 'master' %}
# VRRP giữa các master (keepalived)
iptables -A "$CHAIN" -p 112 -d 224.0.0.18 -j RETURN
# Chặn port control-plane/etcd/kubelet từ nguồn ngoài cụm
iptables -A "$CHAIN" -p tcp -m multiport --dports 6443,2379,2380,10257,10259,10250 -j DROP
{% else %}
# Chặn kubelet/kube-proxy từ nguồn ngoài cụm
iptables -A "$CHAIN" -p tcp -m multiport --dports 10250,10256 -j DROP
{% endif %}

# Mọi thứ còn lại (SSH 22, HAProxy {{ master_ha.vip_port | default(8443) }}, NodePort…) → để stack xử lý
iptables -A "$CHAIN" -j RETURN

# Gắn jump vào đầu INPUT đúng 1 lần
iptables -C INPUT -j "$CHAIN" 2>/dev/null || iptables -I INPUT 1 -j "$CHAIN"
