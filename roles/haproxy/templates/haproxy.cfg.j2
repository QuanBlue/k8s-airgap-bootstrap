# /etc/haproxy/haproxy.cfg
global
    log stdout format raw daemon info
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy

defaults
    log global
    mode tcp
    option tcplog
    option dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend kube-apiserver_frontend
    bind *:{{ k8s_ha.vip_port }}
    mode tcp
    option tcplog
    default_backend kube-apiserver_backend

backend kube-apiserver_backend
    mode tcp
    option tcp-check
    balance roundrobin
    # Fast detection during bootstrap: check every 2s, mark UP after 1 success,
    # no slowstart so traffic flows the moment apiserver responds.
    default-server inter 2s fastinter 1s downinter 1s rise 1 fall 2 maxconn 250 maxqueue 256 weight 100
{% for host in groups['masters'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:6443 check
{% endfor %}
