apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
kubernetesVersion: v{{ kubernetes_version }}
clusterName: "{{ cluster_name }}"
{% if k8s_ha.enabled | default(false) | bool %}
controlPlaneEndpoint: "{{ k8s_ha.vip_address }}:{{ k8s_ha.vip_port }}"
{% else %}
controlPlaneEndpoint: "{{ hostvars[inventory_hostname]['ansible_host'] }}:6443"
{% endif %}
networking:
  podSubnet: "{{ network.pod_cidr }}"
  serviceSubnet: "{{ network.service_cidr }}"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: "{{ hostvars[inventory_hostname]['ansible_host'] }}"
  bindPort: 6443
nodeRegistration:
  criSocket: unix:///run/containerd/containerd.sock
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
cgroupDriver: systemd
{% if kubelet.pod_logs_dir | default('') | length > 0 %}
podLogsDir: "{{ kubelet.pod_logs_dir }}"
{% endif %}
volumeStatsAggPeriod: "{{ kubelet.volume_stats_agg_period }}"
containerLogMaxSize: "{{ kubelet.container_log_max_size }}"
containerLogMaxFiles: {{ kubelet.container_log_max_files }}
imageGCHighThresholdPercent: {{ kubelet.image_gc_high_threshold_percent }}
imageGCLowThresholdPercent: {{ kubelet.image_gc_low_threshold_percent }}
